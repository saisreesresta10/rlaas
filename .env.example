# RLaaS Environment Configuration Example
# Copy this file to .env and customize for your environment

# ========================================
# Server Configuration
# ========================================
RLAAS_SERVER_HOST=0.0.0.0
RLAAS_SERVER_PORT=8000
RLAAS_SERVER_WORKERS=4
RLAAS_SERVER_RELOAD=false
RLAAS_SERVER_LOG_LEVEL=INFO

# ========================================
# Redis Configuration
# ========================================
RLAAS_REDIS_HOST=redis
RLAAS_REDIS_PORT=6379
RLAAS_REDIS_DB=0
# RLAAS_REDIS_PASSWORD=your_secure_password_here
RLAAS_REDIS_SOCKET_TIMEOUT=5.0
RLAAS_REDIS_SOCKET_CONNECT_TIMEOUT=5.0

# ========================================
# Circuit Breaker Configuration
# ========================================
RLAAS_REDIS_CIRCUIT_BREAKER_ENABLED=true
RLAAS_REDIS_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
RLAAS_REDIS_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30.0
RLAAS_REDIS_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3
RLAAS_REDIS_CIRCUIT_BREAKER_TIMEOUT=0.2

# ========================================
# Default Rate Limiting Rules
# ========================================
RLAAS_DEFAULT_RULES_LIMIT=1000
RLAAS_DEFAULT_RULES_WINDOW_SECONDS=3600
RLAAS_DEFAULT_RULES_BURST=1200

# ========================================
# Metrics Configuration
# ========================================
RLAAS_METRICS_ENABLED=true
RLAAS_METRICS_EXPORT_INTERVAL=60.0
RLAAS_METRICS_MAX_AGE=3600.0

# ========================================
# Logging Configuration
# ========================================
RLAAS_LOG_LEVEL=INFO
RLAAS_STRUCTURED_LOGGING=true
RLAAS_CORRELATION_ID_HEADER=X-Correlation-ID

# ========================================
# Security Configuration
# ========================================
RLAAS_SECURITY_CORS_ENABLED=true
# For development, allow all origins
RLAAS_SECURITY_CORS_ORIGINS=["*"]
# For production, specify allowed origins
# RLAAS_SECURITY_CORS_ORIGINS=["https://yourdomain.com","https://api.yourdomain.com"]
RLAAS_SECURITY_CORS_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
RLAAS_SECURITY_CORS_HEADERS=["*"]

# ========================================
# Environment-Specific Settings
# ========================================

# Development
# RLAAS_SERVER_RELOAD=true
# RLAAS_SERVER_LOG_LEVEL=DEBUG
# RLAAS_SECURITY_CORS_ORIGINS=["*"]

# Production
# RLAAS_SERVER_WORKERS=8
# RLAAS_SERVER_LOG_LEVEL=INFO
# RLAAS_REDIS_PASSWORD=your_secure_password
# RLAAS_SECURITY_CORS_ORIGINS=["https://yourdomain.com"]
# RLAAS_REDIS_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
